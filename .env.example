# 蚂蚁AI导航 - 环境变量配置模板
# 复制此文件为 .env.local 并填写实际值

# ===========================================
# Supabase 数据库配置 (必需)
# ===========================================
# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥 (可在 Supabase 控制台 -> Settings -> API 中找到)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# Coze SDK 配置 (必需 - 用于 AI 生成功能)
# ===========================================
# Coze API 密钥 (从 Coze 平台获取)
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key

# Coze 客户端 ID
COZE_WORKLOAD_IDENTITY_CLIENT_ID=your-client-id

# Coze 客户端密钥
COZE_WORKLOAD_IDENTITY_CLIENT_SECRET=your-client-secret

# Coze API 基础 URL
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn

# Coze 模型基础 URL
COZE_INTEGRATION_MODEL_BASE_URL=https://integration.coze.cn/api/v3

# Coze Token 端点
COZE_WORKLOAD_IDENTITY_TOKEN_ENDPOINT=https://api.coze.cn/.well-known/token
COZE_WORKLOAD_ACCESS_TOKEN_ENDPOINT=https://api.coze.cn/.well-known/token

# ===========================================
# 对象存储配置 (可选 - 用于文件上传)
# ===========================================
# S3 兼容存储服务配置
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name
# S3_REGION=auto
# S3_ENDPOINT=https://your-s3-endpoint.com

# ===========================================
# 应用配置 (可选)
# ===========================================
# 应用运行环境
NODE_ENV=development

# 应用端口 (默认 3000)
PORT=3000

# ===========================================
# 安全配置 (可选)
# ===========================================
# Next.js 密钥用于加密 (生产环境必须设置)
# NEXTAUTH_SECRET=your-random-secret-key
# NEXTAUTH_URL=http://localhost:3000
