INSERT INTO ai_timeline (id, year, month, day, title, title_en, description, category, importance, icon, image, related_person_id, related_url, tags, view_count, created_at) VALUES
(3, 1957, NULL, NULL, '感知机发明', 'Perceptron Invented', '弗兰克·罗森布拉特发明了感知机(Perceptron)，这是第一个人工神经网络模型，为后来的深度学习奠定了基础。', 'breakthrough', 'landmark', '🧠', NULL, NULL, NULL, ARRAY["感知机", "神经网络", "深度学习基础"], 0, '2026-03-12T15:26:09.29661+08:00'),
(4, 1959, NULL, NULL, '"机器学习"术语诞生', 'Machine Learning Term Coined', '亚瑟·塞缪尔首次提出"机器学习"(Machine Learning)这一术语，并开发了世界上第一个自学习程序——跳棋程序。', 'research', 'important', '📚', NULL, NULL, NULL, ARRAY["机器学习", "自学习程序", "游戏AI"], 0, '2026-03-12T15:26:09.29661+08:00'),
(5, 1961, NULL, NULL, 'UNTO解数学定理', 'UNTO Proves Mathematical Theorems', '艾伦·纽厄尔和赫伯特·西蒙开发了UNTO程序，能够证明数学定理，展示了计算机进行逻辑推理的能力。', 'breakthrough', 'important', '🔢', NULL, NULL, NULL, ARRAY["逻辑推理", "定理证明", "符号AI"], 0, '2026-03-12T15:26:09.29661+08:00'),
(6, 1966, NULL, NULL, 'ELIZA聊天机器人诞生', 'ELIZA Chatbot Created', '约瑟夫·魏泽鲍姆开发了ELIZA聊天机器人，这是最早的对话式AI程序之一，能够模拟心理治疗师与用户对话。', 'product', 'important', '💬', NULL, NULL, NULL, ARRAY["聊天机器人", "自然语言处理", "对话AI"], 0, '2026-03-12T15:26:09.29661+08:00'),
(7, 1969, NULL, NULL, '《感知机》出版', 'Perceptrons Book Published', '马文·明斯基和西摩·佩珀特出版《感知机》一书，指出单层感知机的局限性，导致神经网络研究进入"AI寒冬"。', 'research', 'important', '📖', NULL, NULL, NULL, ARRAY["感知机", "AI寒冬", "神经网络局限"], 0, '2026-03-12T15:26:09.29661+08:00'),
(8, 1979, NULL, NULL, '斯坦福购物车', 'Stanford Cart', '汉斯·莫拉维克开发了斯坦福购物车，这是最早的自动驾驶车辆之一，能够在无人干预下穿越房间。', 'product', 'important', '🛒', NULL, NULL, NULL, ARRAY["自动驾驶", "机器人", "计算机视觉"], 0, '2026-03-12T15:26:28.911118+08:00'),
(9, 1980, NULL, NULL, '专家系统商业化', 'Expert Systems Commercialized', '专家系统开始在商业领域广泛应用，XCON、MYCIN等系统展示了AI在特定领域的实用价值，引发第一次AI商业化浪潮。', 'product', 'important', '💼', NULL, NULL, NULL, ARRAY["专家系统", "商业化", "知识工程"], 0, '2026-03-12T15:26:28.911118+08:00'),
(10, 1982, NULL, NULL, 'Hopfield网络提出', 'Hopfield Network Proposed', '约翰·霍普菲尔德提出Hopfield网络，重新点燃了学术界对神经网络研究的兴趣，为后来的深度学习复兴奠定基础。', 'breakthrough', 'important', '🔗', NULL, NULL, NULL, ARRAY["Hopfield网络", "神经网络复兴", "联想记忆"], 0, '2026-03-12T15:26:28.911118+08:00'),
(12, 1988, NULL, NULL, 'IBM深蓝项目启动', 'IBM Deep Blue Project Started', 'IBM启动深蓝国际象棋计算机项目，目标是击败世界象棋冠军，开启了AI在游戏领域的突破之旅。', 'product', 'important', '♟️', NULL, NULL, NULL, ARRAY["深蓝", "国际象棋", "游戏AI"], 0, '2026-03-12T15:26:28.911118+08:00'),
(14, 1998, NULL, NULL, 'LeNet-5卷积神经网络', 'LeNet-5 Convolutional Neural Network', '杨立昆开发LeNet-5卷积神经网络，成功应用于手写数字识别，为现代计算机视觉奠定了基础。', 'breakthrough', 'important', '👁️', NULL, NULL, NULL, ARRAY["CNN", "LeNet", "计算机视觉"], 0, '2026-03-12T15:26:28.911118+08:00'),
(15, 2006, NULL, NULL, 'Hinton提出深度信念网络', 'Deep Belief Networks Proposed', '杰弗里·辛顿提出深度信念网络(DBN)，解决了深度神经网络训练困难的问题，标志着深度学习时代的开启。', 'breakthrough', 'landmark', '🔮', NULL, NULL, NULL, ARRAY["深度信念网络", "深度学习", "神经网络"], 0, '2026-03-12T15:26:51.47104+08:00'),
(17, 2009, NULL, NULL, 'Andrew Ng启动Google Brain项目', 'Google Brain Project Started', '吴恩达与Google合作启动Google Brain项目，探索大规模深度学习，训练了当时最大的神经网络之一。', 'organization', 'important', '🧠', NULL, NULL, NULL, ARRAY["Google Brain", "大规模神经网络", "深度学习"], 0, '2026-03-12T15:26:51.47104+08:00'),
(20, 2012, 11, NULL, 'Google大脑识别猫', 'Google Brain Recognizes Cats', 'Google Brain项目成功让神经网络自动学会识别猫的视频，这是无监督学习的重要突破。', 'breakthrough', 'important', '🐱', NULL, NULL, NULL, ARRAY["无监督学习", "神经网络", "特征学习"], 0, '2026-03-12T15:26:51.47104+08:00'),
(21, 2013, NULL, NULL, 'Word2Vec发布', 'Word2Vec Released', 'Google发布Word2Vec词向量模型，将词语映射到向量空间，开创了词嵌入技术在NLP领域的广泛应用。', 'breakthrough', 'important', '📝', NULL, NULL, NULL, ARRAY["Word2Vec", "词向量", "NLP"], 0, '2026-03-12T15:26:51.47104+08:00'),
(22, 2014, NULL, NULL, 'GAN发明', 'GAN Invented', '伊恩·古德费洛发明生成对抗网络(GAN)，为图像生成、风格迁移等领域带来革命性突破。', 'breakthrough', 'landmark', '🎨', NULL, NULL, NULL, ARRAY["GAN", "生成模型", "图像生成"], 0, '2026-03-12T15:26:51.47104+08:00'),
(23, 2015, NULL, NULL, 'DeepMind被Google收购', 'DeepMind Acquired by Google', 'Google以约5亿美元收购DeepMind，这家由戴维·哈萨比斯创立的AI公司后来成为AI研究的领导者。', 'organization', 'important', '🏢', NULL, NULL, NULL, ARRAY["DeepMind", "Google", "AI公司"], 0, '2026-03-12T15:27:11.107788+08:00'),
(25, 2016, NULL, NULL, 'TensorFlow开源', 'TensorFlow Open Sourced', 'Google开源TensorFlow深度学习框架，大大降低了深度学习的门槛，推动了AI技术的普及和发展。', 'product', 'important', '⚙️', NULL, NULL, NULL, ARRAY["TensorFlow", "开源框架", "深度学习"], 0, '2026-03-12T15:27:11.107788+08:00'),
(26, 2017, 8, NULL, 'YOLO实时目标检测', 'YOLO Real-time Detection', 'Joseph Redmon发布YOLO(You Only Look Once)算法，实现实时目标检测，在自动驾驶等领域有广泛应用。', 'breakthrough', 'important', '👁️', NULL, NULL, NULL, ARRAY["YOLO", "目标检测", "实时识别"], 0, '2026-03-12T15:27:11.107788+08:00'),
(27, 2017, 6, NULL, 'Transformer架构发表', 'Transformer Architecture Published', 'Google发表"Attention Is All You Need"论文，提出Transformer架构，彻底改变了自然语言处理领域，成为大语言模型的基础。', 'breakthrough', 'landmark', '🔑', NULL, NULL, NULL, ARRAY["Transformer", "注意力机制", "NLP革命"], 0, '2026-03-12T15:27:11.107788+08:00'),
(31, 2019, 7, NULL, 'PyTorch成为主流框架', 'PyTorch Becomes Mainstream', 'Facebook的PyTorch框架在学术研究中逐渐超越TensorFlow，成为最流行的深度学习框架之一。', 'product', 'important', '🔥', NULL, NULL, NULL, ARRAY["PyTorch", "深度学习框架", "开源"], 0, '2026-03-12T15:27:33.226451+08:00'),
(37, 2022, 11, 30, 'ChatGPT正式发布', 'ChatGPT Official Launch', 'OpenAI正式发布ChatGPT，基于GPT-3.5，以其强大的对话能力和广泛的应用场景引发全球AI热潮。', 'product', 'landmark', '🚀', NULL, NULL, NULL, ARRAY["ChatGPT", "GPT-3.5", "OpenAI", "AI革命"], 0, '2026-03-12T15:27:33.226451+08:00'),
(38, 2023, 2, 7, 'Bing Chat发布', 'Bing Chat Released', '微软发布集成ChatGPT的Bing Chat，将AI搜索带入主流，Google随后发布Bard竞争。', 'product', 'important', '🔍', NULL, NULL, NULL, ARRAY["Bing Chat", "AI搜索", "微软"], 0, '2026-03-12T15:28:05.629517+08:00'),
(40, 2023, 3, 21, 'Google Bard发布', 'Google Bard Released', 'Google发布对话式AI服务Bard，基于LaMDA模型，与ChatGPT展开竞争。', 'product', 'important', '🌐', NULL, NULL, NULL, ARRAY["Bard", "Google", "对话AI"], 0, '2026-03-12T15:28:05.629517+08:00'),
(41, 2023, 5, 23, '微软Build大会AI主题', 'Microsoft Build AI Focus', '微软Build大会全面聚焦AI，宣布Windows Copilot、Microsoft 365 Copilot等AI产品，AI PC时代开启。', 'product', 'important', '💻', NULL, NULL, NULL, ARRAY["微软", "Copilot", "AI PC"], 0, '2026-03-12T15:28:05.629517+08:00'),
(42, 2023, 7, 12, 'Llama 2开源', 'Llama 2 Open Sourced', 'Meta开源Llama 2大语言模型，免费商用，推动开源大模型生态发展。', 'breakthrough', 'landmark', '🦙', NULL, NULL, NULL, ARRAY["Llama 2", "开源模型", "Meta"], 0, '2026-03-12T15:28:05.629517+08:00'),
(43, 2023, 9, 21, 'Amazon投资Anthropic', 'Amazon Invests in Anthropic', '亚马逊宣布向Anthropic投资最多40亿美元，AI领域投资热潮持续升温。', 'organization', 'important', '💰', NULL, NULL, NULL, ARRAY["Anthropic", "Claude", "亚马逊投资"], 0, '2026-03-12T15:28:05.629517+08:00'),
(44, 2023, 11, 6, 'OpenAI首届开发者大会', 'OpenAI DevDay', 'OpenAI举办首届开发者大会，发布GPT-4 Turbo、GPTs自定义AI助手、Assistants API等重要更新。', 'product', 'important', '🎤', NULL, NULL, NULL, ARRAY["OpenAI", "GPTs", "开发者大会"], 0, '2026-03-12T15:28:05.629517+08:00'),
(45, 2023, 11, 17, 'Sam Altman短暂离职风波', 'Sam Altman Briefly Ousted', 'OpenAI董事会突然解雇CEO Sam Altman，引发行业震动，5天后Altman回归，揭示AI公司治理挑战。', 'other', 'important', '⚡', NULL, NULL, NULL, ARRAY["OpenAI", "治理危机", "Altman"], 0, '2026-03-12T15:28:05.629517+08:00'),
(46, 2024, 2, 15, 'Sora视频生成模型', 'Sora Video Generation Model', 'OpenAI发布Sora视频生成模型，可根据文本生成长达60秒的高质量视频，开创视频生成新时代。', 'breakthrough', 'landmark', '🎬', NULL, NULL, NULL, ARRAY["Sora", "视频生成", "OpenAI"], 0, '2026-03-12T15:28:05.629517+08:00'),
(47, 2024, 2, 22, 'Gemini 1.5 Pro发布', 'Gemini 1.5 Pro Released', 'Google发布Gemini 1.5 Pro，支持100万token上下文窗口，大幅提升长文本处理能力。', 'breakthrough', 'important', '💎', NULL, NULL, NULL, ARRAY["Gemini", "Google", "长上下文"], 0, '2026-03-12T15:28:05.629517+08:00'),
(48, 2024, 5, 13, 'GPT-4o发布', 'GPT-4o Released', 'OpenAI发布GPT-4o，实现实时语音、视觉、文本多模态交互，响应速度大幅提升。', 'breakthrough', 'landmark', '🎯', NULL, NULL, NULL, ARRAY["GPT-4o", "多模态", "实时交互", "OpenAI"], 0, '2026-03-12T15:28:05.629517+08:00'),
(49, 2024, 6, 20, 'Claude 3.5 Sonnet发布', 'Claude 3.5 Sonnet Released', 'Anthropic发布Claude 3.5 Sonnet，在多项基准测试中超越GPT-4o，展现强大的编程和推理能力。', 'breakthrough', 'important', '🎭', NULL, NULL, NULL, ARRAY["Claude", "Anthropic", "大语言模型"], 0, '2026-03-12T15:28:05.629517+08:00'),
(50, 2024, 9, 12, 'OpenAI o1推理模型', 'OpenAI o1 Reasoning Model', 'OpenAI发布o1系列模型，专注于复杂推理任务，在数学、编程、科学问题上表现突破性进展。', 'breakthrough', 'landmark', '🧩', NULL, NULL, NULL, ARRAY["o1", "推理模型", "OpenAI"], 0, '2026-03-12T15:28:05.629517+08:00'),
(51, 2024, 10, 22, 'Claude 3.5 Sonnet更新', 'Claude 3.5 Sonnet Update', 'Anthropic发布Claude 3.5 Sonnet更新版和新版Haiku，同时推出Computer Use功能，AI可以操作电脑。', 'breakthrough', 'important', '🖥️', NULL, NULL, NULL, ARRAY["Claude", "Computer Use", "Anthropic"], 0, '2026-03-12T15:28:05.629517+08:00'),
(52, 2024, 12, 5, 'OpenAI 12天发布会', 'OpenAI 12 Days Event', 'OpenAI举办12天连续发布会，发布o1正式版、Sora预览、Canvas、强化微调等多项重要更新。', 'product', 'important', '🎁', NULL, NULL, NULL, ARRAY["OpenAI", "o1", "Sora", "Canvas"], 0, '2026-03-12T15:28:05.629517+08:00'),
(54, 2025, 1, 20, 'DeepSeek发布R1推理模型', 'DeepSeek releases R1 reasoning model', 'DeepSeek发布R1推理模型，在数学、代码和推理任务上达到GPT-o1级别性能，以极低成本实现顶级推理能力，引发全球关注。该模型完全开源，推动了中国AI开源生态发展。', 'breakthrough', 'landmark', '🧠', NULL, NULL, NULL, ARRAY["DeepSeek", "推理模型", "开源AI", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(55, 2024, 12, 26, 'DeepSeek发布V3模型', 'DeepSeek releases V3 model', 'DeepSeek发布V3大语言模型，采用MoE架构，671B参数激活37B，性能对标GPT-4o，训练成本仅557.8万美元，证明中国AI在成本效益上的突破。', 'breakthrough', 'important', '🚀', NULL, NULL, NULL, ARRAY["DeepSeek", "MoE", "大语言模型", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(56, 2024, 9, 19, '阿里发布通义千问2.5', 'Alibaba releases Qwen2.5', '阿里巴巴发布通义千问2.5系列模型，涵盖0.5B到72B多个尺寸，开源版本在多项评测中超越Llama等国际开源模型，成为全球最受欢迎的开源模型之一。', 'product', 'important', '🌟', NULL, NULL, NULL, ARRAY["阿里", "通义千问", "开源模型", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(57, 2024, 5, 6, 'DeepSeek发布V2模型', 'DeepSeek releases V2 model', 'DeepSeek发布V2模型，创新性采用MLA（Multi-Head Latent Attention）架构，大幅降低推理成本，性能接近GPT-4级别。', 'breakthrough', 'important', '💡', NULL, NULL, NULL, ARRAY["DeepSeek", "MLA", "大语言模型", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(58, 2024, 5, 15, '字节跳动豆包大模型正式发布', 'ByteDance releases Doubao model', '字节跳动正式发布豆包大模型，日活用户突破千万，成为中国用户量最大的AI助手之一。豆包在视频理解、多模态能力上表现突出。', 'product', 'important', '🤖', NULL, NULL, NULL, ARRAY["字节跳动", "豆包", "AI助手", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(60, 2023, 3, 14, '智谱AI开源ChatGLM-6B', 'Zhipu AI open-sources ChatGLM-6B', '清华系智谱AI开源ChatGLM-6B模型，成为首个开源的中文对话大模型，推动了中国开源大模型生态发展。', 'research', 'important', '📚', NULL, NULL, NULL, ARRAY["智谱AI", "ChatGLM", "开源模型", "清华"], 0, '2026-03-12T15:56:06.48548+08:00'),
(61, 2023, 7, 7, '华为发布盘古大模型3.0', 'Huawei releases Pangu Model 3.0', '华为发布盘古大模型3.0，面向工业场景，在气象预测、药物研发、矿山等行业应用取得突破。', 'product', 'important', '🏔️', NULL, NULL, NULL, ARRAY["华为", "盘古", "行业大模型", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(62, 2022, 11, 5, '商汤科技发布书生大模型', 'SenseTime releases InternLM model', '商汤科技发布书生大模型，专注于通用视觉和多模态理解，在多个视觉基准测试中取得领先成绩。', 'product', 'normal', '📖', NULL, NULL, NULL, ARRAY["商汤科技", "书生", "多模态", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(63, 2021, 3, 25, '旷视科技发布MegEngine深度学习框架', 'Megvii releases MegEngine framework', '旷视科技开源天元MegEngine深度学习框架，成为中国自主研发的三大AI框架之一，推动了国产AI基础设施发展。', 'breakthrough', 'important', '⚙️', NULL, NULL, NULL, ARRAY["旷视科技", "MegEngine", "AI框架", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(64, 2020, 5, 20, '百度飞桨用户突破100万', 'Baidu PaddlePaddle reaches 1M users', '百度飞桨深度学习平台开发者用户突破100万，成为中国最大的国产深度学习框架，服务企业超10万家。', 'organization', 'important', '🌊', NULL, NULL, NULL, ARRAY["百度", "飞桨", "深度学习框架", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(65, 2019, 8, 23, '华为发布昇腾910 AI芯片', 'Huawei releases Ascend 910 AI chip', '华为发布昇腾910 AI训练芯片，算力达256 TeraFLOPS，成为当时单芯片计算密度最大的AI芯片，标志着中国在AI芯片领域的突破。', 'breakthrough', 'landmark', '🔥', NULL, NULL, NULL, ARRAY["华为", "昇腾", "AI芯片", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(66, 2018, 4, 9, '商汤科技获6亿美元融资', 'SenseTime raises $600M funding', '商汤科技获得6亿美元C轮融资，估值超30亿美元，成为当时全球估值最高的AI独角兽企业。', 'organization', 'important', '💰', NULL, NULL, NULL, ARRAY["商汤科技", "融资", "AI独角兽", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(67, 2017, 7, 8, '中国发布新一代AI发展规划', 'China releases AI Development Plan', '国务院印发《新一代人工智能发展规划》，提出到2030年中国AI理论、技术与应用总体达到世界领先水平，成为全球AI创新中心。', 'organization', 'landmark', '📋', NULL, NULL, NULL, ARRAY["政策", "AI规划", "国家战略", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(68, 2016, 11, 23, '科大讯飞发布讯飞超脑计划', 'iFlytek launches HyperBrain project', '科大讯飞发布讯飞超脑计划，致力于让机器能听会说、能理解会思考，推动中国智能语音技术领先全球。', 'research', 'important', '🎤', NULL, NULL, NULL, ARRAY["科大讯飞", "语音识别", "超脑计划", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
(69, 2015, 5, 15, '百度硅谷AI实验室成立', 'Baidu establishes Silicon Valley AI Lab', '百度在硅谷成立人工智能实验室，由吴恩达领导，推动百度在自动驾驶、语音识别、图像识别等领域的AI研究。', 'organization', 'important', '🏢', NULL, NULL, NULL, ARRAY["百度", "AI实验室", "自动驾驶", "中国AI"], 0, '2026-03-12T15:56:06.48548+08:00'),
