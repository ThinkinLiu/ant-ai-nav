(116, '俞士纶', 'Philip Yu', 'https://ui-avatars.com/api/?name=Philip+Yu&background=3B82F6&color=fff&size=256&bold=true', '大数据专家', '伊利诺伊大学芝加哥分校教授，在大数据挖掘和社交网络分析方面有重要贡献。', NULL, NULL, NULL, NULL, '美国', 'research', ARRAY["大数据", "社交网络", "数据挖掘"], false, 0, 1955, '2026-03-12T16:02:37.181501+08:00', NULL),
