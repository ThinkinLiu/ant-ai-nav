(8, '李开复', 'Kai-Fu Lee', 'https://ui-avatars.com/api/?name=Kai-Fu+Lee&background=F59E0B&color=fff&size=256&bold=true', '创新工场董事长', '华人AI专家、企业家，创新工场董事长。曾任Google、微软、苹果高管，著有《AI·未来》等畅销书。', '李开复是华人在AI领域最知名的代表人物之一，曾任Google中国总裁、微软亚洲研究院院长。', ARRAY["创新工场创始人", "Google中国前总裁", "微软亚洲研究院前院长", "AI未来作者"], '创新工场', 'https://www.chuangxin.com/', '中国', 'entrepreneur', ARRAY["人工智能", "创业投资", "AI教育"], true, 1, 1961, '2026-03-12T15:18:43.73658+08:00', NULL),
(5, '杨立昆', 'Yann LeCun', 'https://ui-avatars.com/api/?name=Yann+LeCun&background=EA580C&color=fff&size=256&bold=true', '卷积神经网络之父', '卷积神经网络(CNN)的开创者，2018年图灵奖获得者，Meta首席AI科学家。', '杨立昆是卷积神经网络的先驱，他在1980年代末开发的LeNet是第一个成功的CNN架构。', ARRAY["图灵奖获得者", "卷积神经网络创始人", "LeNet架构设计者", "Meta首席AI科学家"], 'Meta/NYU', 'https://www.nyu.edu/', '美国', 'researcher', ARRAY["深度学习", "计算机视觉", "卷积神经网络"], true, 0, 1960, '2026-03-12T15:18:27.202212+08:00', NULL),
