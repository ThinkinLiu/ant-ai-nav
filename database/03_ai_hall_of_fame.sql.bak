(18, '克劳德·香农', 'Claude Shannon', 'https://ui-avatars.com/api/?name=Claude+Shannon&background=4F46E5&color=fff&size=256&bold=true', '信息论之父', '美国数学家和电气工程师，创立信息论，为数字通信和计算机科学奠定基础。其《通信的数学理论》是现代信息论的奠基之作。', NULL, NULL, NULL, NULL, '美国', 'pioneer', ARRAY["信息论", "数字通信", "布尔代数"], false, 0, 1916, '2026-03-12T15:59:00.652122+08:00', NULL),
(19, '诺伯特·维纳', 'Norbert Wiener', 'https://ui-avatars.com/api/?name=Norbert+Wiener&background=7C3AED&color=fff&size=256&bold=true', '控制论创始人', '美国数学家和哲学家，创立控制论，提出反馈理论，对自动化和人工智能发展产生深远影响。', NULL, NULL, NULL, NULL, '美国', 'pioneer', ARRAY["控制论", "反馈理论", "自动化"], false, 0, 1894, '2026-03-12T15:59:00.652122+08:00', NULL),
(24, '爱德华·费根鲍姆', 'Edward Feigenbaum', 'https://ui-avatars.com/api/?name=Edward+Feigenbaum&background=4F46E5&color=fff&size=256&bold=true', '专家系统之父', '美国计算机科学家，被誉为"专家系统之父"，开发了DENDRAL等早期专家系统，推动了知识工程的发展。', NULL, NULL, NULL, NULL, '美国', 'pioneer', ARRAY["专家系统", "知识工程", "DENDRAL"], false, 0, 1936, '2026-03-12T15:59:00.652122+08:00', NULL),
(39, '克里斯托弗·曼宁', 'Christopher Manning', 'https://ui-avatars.com/api/?name=Christopher+Manning&background=6366F1&color=fff&size=256&bold=true', 'NLP领域权威', '斯坦福大学教授，自然语言处理领域权威专家，开发了Stanford NLP工具包，推动了NLP研究和教育。', NULL, NULL, NULL, NULL, '美国', 'nlp', ARRAY["自然语言处理", "Stanford NLP", "深度学习NLP"], false, 0, 1965, '2026-03-12T15:59:50.379686+08:00', NULL),
(40, '理查德·索彻', 'Richard Socher', 'https://ui-avatars.com/api/?name=Richard+Socher&background=6366F1&color=fff&size=256&bold=true', 'NLP研究者、Salesforce首席科学家', 'Salesforce首席科学家，斯坦福大学博士，在自然语言处理和计算机视觉领域有重要贡献，创建了多个NLP数据集和模型。', NULL, NULL, NULL, NULL, '美国', 'nlp', ARRAY["自然语言处理", "深度学习", "多模态"], false, 0, 1982, '2026-03-12T15:59:50.379686+08:00', NULL),
(41, '托马斯·米科洛夫', 'Tomas Mikolov', 'https://ui-avatars.com/api/?name=Tomas+Mikolov&background=6366F1&color=fff&size=256&bold=true', 'Word2Vec作者', 'Facebook AI Research研究科学家，Word2Vec作者，在词嵌入和语言模型方面做出重要贡献。', NULL, NULL, NULL, NULL, '捷克', 'nlp', ARRAY["Word2Vec", "词嵌入", "语言模型"], false, 0, 1979, '2026-03-12T15:59:50.379686+08:00', NULL),
(58, '梁文锋', 'Liang Wenfeng', 'https://ui-avatars.com/api/?name=Wenfeng+Liang&background=EF4444&color=fff&size=256&bold=true', 'DeepSeek创始人', 'DeepSeek创始人兼CEO，幻方量化创始人，带领团队发布DeepSeek-V3、R1等突破性模型，以极低成本实现顶级AI性能，开创中国AI开源新时代。', NULL, NULL, NULL, NULL, '中国', 'entrepreneur', ARRAY["DeepSeek", "开源AI", "大模型"], true, 0, 1985, '2026-03-12T16:00:43.681017+08:00', NULL),
(76, '田奇', 'Qi Tian', 'https://ui-avatars.com/api/?name=Qi+Tian&background=14B8A6&color=fff&size=256&bold=true', '华为云AI首席科学家', '华为云AI首席科学家，在计算机视觉和多媒体分析领域有重要贡献，曾任华为诺亚方舟实验室主任。', NULL, NULL, NULL, NULL, '中国', 'research', ARRAY["华为", "计算机视觉", "AI研究"], false, 0, 1965, '2026-03-12T16:01:06.880144+08:00', NULL),
