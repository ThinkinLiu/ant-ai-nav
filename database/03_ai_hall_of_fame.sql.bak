(1, '艾伦·图灵', 'Alan Turing', 'https://ui-avatars.com/api/?name=Alan+Turing&background=4F46E5&color=fff&size=256&bold=true', '计算机科学之父', '英国数学家、逻辑学家，被誉为计算机科学和人工智能之父。1950年提出著名的"图灵测试"，为人工智能领域奠定了理论基础。', '艾伦·图灵是20世纪最伟大的数学家和计算机科学家之一。他在二战期间破解了德国的恩尼格玛密码，对盟军胜利做出了重大贡献。', ARRAY["提出图灵机概念", "提出图灵测试", "破解恩尼格玛密码", "计算机科学奠基人"], '剑桥大学', 'https://www.cam.ac.uk/', '英国', 'pioneer', ARRAY["计算机科学", "人工智能", "密码学", "数学"], true, 3, 1912, '2026-03-12T15:18:04.900668+08:00', NULL),
(10, '安德烈·卡帕西', 'Andrej Karpathy', 'https://ui-avatars.com/api/?name=Andrej+Karpathy&background=10B981&color=fff&size=256&bold=true', 'AI教育先驱', '前Tesla AI总监、OpenAI创始成员。以AI教育和开源贡献闻名，创建了最受欢迎的深度学习课程。', '安德烈·卡帕西是AI领域最具影响力的教育者之一，创建的CS231n课程是深度学习领域最受欢迎的课程之一。', ARRAY["Tesla前AI总监", "OpenAI创始成员", "CS231n课程创建者", "AI教育先驱"], 'Eureka Labs', 'https://karpathy.ai/', '美国', 'engineer', ARRAY["计算机视觉", "自动驾驶", "AI教育"], false, 0, 1986, '2026-03-12T15:18:58.300458+08:00', NULL),
(30, '何恺明', 'Kaiming He', 'https://ui-avatars.com/api/?name=Kaiming+He&background=EC4899&color=fff&size=256&bold=true', 'ResNet作者', '麻省理工学院教授，ResNet、Mask R-CNN等突破性论文作者，在计算机视觉领域做出里程碑贡献。何恺明的工作被认为是深度学习最重要的突破之一。', NULL, NULL, NULL, NULL, '中国', 'vision', ARRAY["ResNet", "Mask R-CNN", "计算机视觉"], false, 0, 1983, '2026-03-12T15:59:28.382656+08:00', NULL),
(29, '贾扬清', 'Yangqing Jia', 'https://ui-avatars.com/api/?name=Yangqing+Jia&background=EC4899&color=fff&size=256&bold=true', 'Caffe框架作者', '加州大学伯克利分校博士，Caffe深度学习框架作者，曾任Facebook AI Research研究科学家，现任阿里巴巴技术副总裁。', NULL, NULL, NULL, NULL, '中国', 'engineering', ARRAY["Caffe", "深度学习框架", "计算机视觉"], false, 0, 1985, '2026-03-12T15:59:28.382656+08:00', NULL),
