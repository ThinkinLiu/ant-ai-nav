(43, '达里奥·阿莫代伊', 'Dario Amodei', 'https://ui-avatars.com/api/?name=Dario+Amodei&background=D97706&color=fff&size=256&bold=true', 'Anthropic创始人', 'Anthropic公司创始人兼CEO，前OpenAI研究副总裁，专注于AI安全和对齐研究。', NULL, NULL, NULL, NULL, '美国', 'entrepreneur', ARRAY["AI安全", "Anthropic", "Claude"], false, 0, 1983, '2026-03-12T15:59:50.379686+08:00', NULL),
