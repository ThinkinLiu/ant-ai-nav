# 生产环境配置 - Coze 部署使用
# 请复制此文件为 .env.production 并填写实际值
# ⚠️ 重要：请勿将包含真实密钥的 .env.production 提交到 Git！

# ===========================================
# Supabase 配置（必需）
# ===========================================
# 请从 Supabase 控制台获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# Coze 特定的环境变量（运行时使用）
# ===========================================
# 请从 Coze 控制台获取
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# Coze 认证配置（敏感信息）
# ===========================================
# 请从 Coze 控制台获取 - 这些是敏感信息！
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key
COZE_WORKLOAD_IDENTITY_CLIENT_ID=your-coze-client-id
COZE_WORKLOAD_IDENTITY_CLIENT_SECRET=your-coze-client-secret
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn
COZE_INTEGRATION_MODEL_BASE_URL=https://integration.coze.cn/api/v3
COZE_WORKLOAD_IDENTITY_TOKEN_ENDPOINT=https://api.coze.cn/.well-known/token
COZE_WORKLOAD_ACCESS_TOKEN_ENDPOINT=https://api.coze.cn/.well-known/token

# ===========================================
# 应用配置
# ===========================================
NODE_ENV=production
PORT=5000
