# 构建时环境变量配置模板
# 此文件用于在构建时提供必要的环境变量
# 复制此文件为 .env.build 并填写实际值
# 
# ⚠️ 警告：.env.build 文件已被 .gitignore 忽略，不会提交到 GitHub
#    请不要将包含真实凭据的 .env.build 文件提交到版本控制系统

# Supabase 配置（必需）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Coze API 配置（可选 - AI 功能）
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key
COZE_WORKLOAD_IDENTITY_CLIENT_ID=your-client-id
COZE_WORKLOAD_IDENTITY_CLIENT_SECRET=your-client-secret
COZE_INTEGRATION_BASE_URL=https://integration.coze.cn
